{# Breadcrumb partial - pass breadcrumbs array [{label, url}] #}
<nav class="absolute top-20 left-0 z-40 w-full bg-transparent">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
    <ol class="flex items-center space-x-2 text-sm text-white/80">
      <li><a href="{{ '/' | locale_url }}" class="hover:text-white transition-colors">{{ translations[lang].siteTitle }}</a></li>
      {% for crumb in breadcrumbs %}
        <li class="flex items-center space-x-2">
          <span>›</span>
          {% if crumb.url %}
            <a href="{{ crumb.url }}" class="hover:text-white transition-colors">{{ crumb.label }}</a>
          {% else %}
            <span class="text-white font-medium">{{ crumb.label }}</span>
          {% endif %}
        </li>
      {% endfor %}
    </ol>
  </div>
</nav>
