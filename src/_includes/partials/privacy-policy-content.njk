{# Reusable Privacy Policy content.
   - Text lives in src/_data/policy.json under privacyPolicy[lang]
   - No left/right padding on the main container (per requirement)
   - Emoji-free (professional tone)
#}

{# Nunjucks in 11ty doesn't reliably support JS-style ternary in `{% set %}` across all configs.
   Use explicit `{% if %}` blocks to avoid parse errors. #}

{% set policyLang = null %}
{% if policy and policy.privacyPolicy and policy.privacyPolicy[lang] %}
  {% set policyLang = policy.privacyPolicy[lang] %}
{% endif %}

{% set policyMeta = null %}
{% if policy and policy.meta %}
  {% set policyMeta = policy.meta %}
{% endif %}

{% set policyLastUpdated = null %}
{% if policyMeta and policyMeta.lastUpdated and policyMeta.lastUpdated[lang] %}
  {% set policyLastUpdated = policyMeta.lastUpdated[lang] %}
{% endif %}

<section class="bg-white">
  {# Full-width container: intentionally no px-* padding #}
  <div class="w-full">
    <div class="py-10 md:py-14">
      {# Match the Page Header container width (max-w-7xl) and padding (px-4 sm:px-6 lg:px-8)
         so the left/right edges align with the title in `page-header.njk`. #}
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        {# Keep readable line-length while keeping the same left edge as the page title #}
        <div class="w-full max-w-5xl">
          <article class="text-gray-800">
            <header class="mb-8 md:mb-10 border-b border-gray-200 pb-6">
              <h2 class="text-3xl md:text-4xl font-bold text-gray-900">
                {{ policyLang.title }}
              </h2>

              {% if policyLastUpdated %}
                <p class="mt-3 text-base md:text-lg text-gray-600">
                  <span class="font-semibold text-gray-800">
                    {% if lang == 'it' %}Ultimo aggiornamento:{% else %}Last updated:{% endif %}
                  </span>
                  {{ policyLastUpdated }}
                </p>
              {% endif %}

              <p class="mt-4 text-base md:text-lg leading-relaxed text-gray-700">
                {{ policyLang.intro }}
              </p>
            </header>

            <div class="space-y-10">
              {% for section in policyLang.sections %}
                <section aria-labelledby="{{ section.id }}">
                  <h3 id="{{ section.id }}" class="text-2xl md:text-3xl font-bold text-gray-900">
                    {{ section.number }}. {{ section.title }}
                  </h3>

                  {% for block in section.blocks %}
                    {% if block.type == 'paragraph' %}
                      <p class="mt-4 text-gray-700 leading-relaxed">{{ block.text }}</p>

                    {% elseif block.type == 'list' %}
                      <ul class="mt-3 list-disc pl-6 text-gray-700 space-y-1">
                        {% for item in block.items %}
                          <li>{{ item }}</li>
                        {% endfor %}
                      </ul>

                    {% elseif block.type == 'address' %}
                      <div class="mt-4 rounded-xl border border-gray-200 bg-gray-50 p-5 md:p-6">
                        <p class="text-gray-800 leading-relaxed">
                          {% for line in block.lines %}
                            {% if line | trim | lower | slice(0, 6) == 'email:' %}
                              {% set email = (line | replace('Email:', '') | replace('email:', '') | trim) %}
                              Email:
                              <a class="text-blue-700 hover:text-blue-900 underline" href="mailto:{{ email }}">{{ email }}</a>
                            {% else %}
                              {% if loop.first %}<strong>{{ line }}</strong>{% else %}{{ line }}{% endif %}{% if not loop.last %}<br>{% endif %}
                            {% endif %}
                          {% endfor %}
                        </p>
                      </div>

                    {% elseif block.type == 'subsection' %}
                      <div class="mt-6">
                        <h4 class="text-lg md:text-xl font-semibold text-gray-900">{{ block.title }}</h4>
                        {% for subBlock in block.blocks %}
                          {% if subBlock.type == 'paragraph' %}
                            <p class="mt-2 text-gray-700 leading-relaxed">{{ subBlock.text }}</p>
                          {% elseif subBlock.type == 'list' %}
                            <ul class="mt-3 list-disc pl-6 text-gray-700 space-y-1">
                              {% for item in subBlock.items %}
                                <li>{{ item }}</li>
                              {% endfor %}
                            </ul>
                          {% endif %}
                        {% endfor %}
                      </div>

                    {% elseif block.type == 'providers' %}
                      <div class="mt-5 grid grid-cols-1 md:grid-cols-2 gap-4">
                        {% for provider in block.items %}
                          <div class="rounded-xl border border-gray-200 p-5 md:p-6">
                            <h4 class="text-lg font-semibold text-gray-900">{{ provider.name }}</h4>
                            <div class="mt-2 text-gray-700 leading-relaxed space-y-1">
                              {% for detail in provider.details %}
                                <p>{{ detail }}</p>
                              {% endfor %}
                            </div>
                          </div>
                        {% endfor %}
                      </div>

                    {% elseif block.type == 'callout' %}
                      {% set calloutClasses = 'rounded-xl border p-5 md:p-6 mt-6' %}
                      {% if block.variant == 'warning' %}
                        {% set calloutClasses = calloutClasses + ' border-amber-200 bg-amber-50' %}
                        {% set titleClasses = 'text-lg md:text-xl font-semibold text-amber-900' %}
                        {% set bodyTextClasses = 'text-amber-900/90' %}
                      {% else %}
                        {% set calloutClasses = calloutClasses + ' border-gray-200 bg-gray-50' %}
                        {% set titleClasses = 'text-lg md:text-xl font-semibold text-gray-900' %}
                        {% set bodyTextClasses = 'text-gray-700' %}
                      {% endif %}

                      <div class="{{ calloutClasses }}">
                        {% if block.title %}
                          <h4 class="{{ titleClasses }}">{{ block.title }}</h4>
                        {% endif %}

                        {% for calloutBlock in block.blocks %}
                          {% if calloutBlock.type == 'paragraph' %}
                            <p class="mt-2 {{ bodyTextClasses }} leading-relaxed">{{ calloutBlock.text }}</p>
                          {% elseif calloutBlock.type == 'list' %}
                            <ul class="mt-3 list-disc pl-6 {{ bodyTextClasses }} space-y-1">
                              {% for item in calloutBlock.items %}
                                <li>{{ item }}</li>
                              {% endfor %}
                            </ul>
                          {% endif %}
                        {% endfor %}
                      </div>
                    {% endif %}
                  {% endfor %}
                </section>
              {% endfor %}
            </div>
          </article>
        </div>
      </div>
    </div>
  </div>
</section>
