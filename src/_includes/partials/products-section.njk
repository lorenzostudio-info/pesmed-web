{# Products section - used on homepage AND products index page #}
<section class="py-16 md:py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">{{ translations[lang].productsTitle }}</h2>
      <p class="text-gray-600 max-w-4xl mx-auto text-lg md:text-xl leading-relaxed">{{ translations[lang].productsIntro }}</p>
    </div>

    {% set categoryIcons = {
      "cryotherapy-ablation": '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v2m0 14v2m-7-9H3m18 0h-2m-2.636-5.364l-1.414 1.414M7.05 16.95l-1.414 1.414m0-12.728l1.414 1.414M16.95 16.95l1.414 1.414M12 8a4 4 0 100 8 4 4 0 000-8z"/>',
      "electroporation-therapy": '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>',
      "surgical-navigation-imaging": '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/>'
    } %}

    {% set categoryColors = {
      "cryotherapy-ablation": { "bg": "bg-sky-50", "border": "border-sky-200", "accent": "text-sky-700", "chip": "bg-sky-100 text-sky-700", "iconBg": "bg-sky-100" },
      "electroporation-therapy": { "bg": "bg-amber-50", "border": "border-amber-200", "accent": "text-amber-700", "chip": "bg-amber-100 text-amber-700", "iconBg": "bg-amber-100" },
      "surgical-navigation-imaging": { "bg": "bg-emerald-50", "border": "border-emerald-200", "accent": "text-emerald-700", "chip": "bg-emerald-100 text-emerald-700", "iconBg": "bg-emerald-100" }
    } %}

    {% set categories = products | getCategories %}

    {# Short display names for the product cards #}
    {% set shortNames = {
      "cryotherapy-prosense": { "en": "ProSense", "it": "ProSense" },
      "robotic-navigation-micromate": { "en": "Micromate", "it": "Micromate" },
      "endoscopic-electroporation-endove": { "en": "EndoVE", "it": "EndoVE" },
      "cutaneous-electroporation-cutis": { "en": "CUTIS", "it": "CUTIS" },
      "patient-positioning-ifix": { "en": "iFIX", "it": "iFIX" },
      "biomarker-analysis-pearlfit": { "en": "PearlFit", "it": "PearlFit" },
      "3d-ultrasound-tomography-piur": { "en": "PIUR Infinity", "it": "PIUR Infinity" }
    } %}

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
      {% for cat in categories %}
        {% set catProducts = products | filterByCategory(cat) %}
        {% set colors = categoryColors[cat] %}
        {% set icon = categoryIcons[cat] %}
        {% set catName = translations[lang].categories[cat] %}

        <div class="rounded-2xl border-2 {{ colors.border }} {{ colors.bg }} p-7">
          <div class="flex items-center mb-7">
            <div class="{{ colors.iconBg }} rounded-xl p-3 mr-4 shrink-0">
              <svg class="w-7 h-7 {{ colors.accent }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">{{ icon | safe }}</svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 leading-tight">{{ catName }}</h3>
          </div>

          <div class="space-y-4">
            {% for product in catProducts %}
              {% set displayName = shortNames[product.slug][lang] if shortNames[product.slug] else (product.name[lang] | default(product.name.it)) %}
              <a href="{{ '/' + lang + '/products/' + product.slug + '/' }}" class="group block bg-white/90 border border-white rounded-xl px-5 py-4 hover:border-gray-200 hover:shadow-md transition-all duration-200">
                <div class="flex items-center justify-between gap-4">
                  <div class="min-w-0">
                    <p class="text-lg font-semibold text-gray-900 group-hover:text-blue-600 transition-colors truncate">{{ displayName }}</p>
                    <p class="text-sm text-gray-500 truncate mt-1">{{ product.manufacturer }}</p>
                  </div>
                  <div class="shrink-0">
                    <span class="inline-flex items-center text-blue-600 text-sm font-semibold group-hover:translate-x-1 transition-transform duration-200">
                      {{ translations[lang].viewProduct }}
                      <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </span>
                  </div>
                </div>
              </a>
            {% endfor %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
