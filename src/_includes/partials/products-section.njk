{# Products section - used on homepage AND products index page #}
{# On homepage: scroll-triggered bg transition from white to #2A65C1 #}
{# On products index page: plain white, no color effects #}
{# On other pages: static #2A65C1 background #}

{% set isHome = (title == "Home") %}
{% set isProductsPage = (title == "Prodotti" or title == "Products" or title == "Tecnologie" or title == "Technologies") %}

<section
