{# Products section - used on homepage AND products index page #}
<section class="py-12 md:py-16 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">{{ translations[lang].productsTitle }}</h2>
      <p class="text-gray-600 max-w-3xl mx-auto text-base md:text-lg">{{ translations[lang].productsIntro }}</p>
    </div>

    {% set categoryIcons = {
      "cryotherapy-ablation": '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v2m0 14v2m-7-9H3m18 0h-2m-2.636-5.364l-1.414 1.414M7.05 16.95l-1.414 1.414m0-12.728l1.414 1.414M16.95 16.95l1.414 1.414M12 8a4 4 0 100 8 4 4 0 000-8z"/>',
      "electroporation-therapy": '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>',
      "surgical-navigation-imaging": '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/>'
    } %}

    {% set categoryColors = {
      "cryotherapy-ablation": { "bg": "bg-sky-50", "border": "border-sky-200", "accent": "text-sky-700", "chip": "bg-sky-100 text-sky-700", "iconBg": "bg-sky-100" },
      "electroporation-therapy": { "bg": "bg-amber-50", "border": "border-amber-200", "accent": "text-amber-700", "chip": "bg-amber-100 text-amber-700", "iconBg": "bg-amber-100" },
      "surgical-navigation-imaging": { "bg": "bg-emerald-50", "border": "border-emerald-200", "accent": "text-emerald-700", "chip": "bg-emerald-100 text-emerald-700", "iconBg": "bg-emerald-100" }
    } %}

    {% set categories = products | getCategories %}

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
      {% for cat in categories %}
        {% set catProducts = products | filterByCategory(cat) %}
        {% set colors = categoryColors[cat] %}
        {% set icon = categoryIcons[cat] %}
        {% set catName = translations[lang].categories[cat] %}

        <div class="rounded-xl border {{ colors.border }} {{ colors.bg }} p-5">
          <div class="flex items-center justify-between mb-4">
            <div class="flex items-center min-w-0">
              <div class="{{ colors.iconBg }} rounded-lg p-2.5 mr-3">
                <svg class="w-5 h-5 {{ colors.accent }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">{{ icon | safe }}</svg>
              </div>
              <h3 class="text-base font-bold text-gray-900 leading-tight">{{ catName }}</h3>
            </div>
            <span class="text-xs font-semibold px-2 py-1 rounded-full {{ colors.chip }}">{{ catProducts | length }}</span>
          </div>

          <div class="space-y-2.5">
            {% for product in catProducts %}
              <a href="{{ '/' + lang + '/products/' + product.slug + '/' }}" class="group block bg-white/90 border border-white rounded-lg px-3 py-2.5 hover:border-gray-200 hover:shadow-sm transition-all duration-200">
                <div class="flex items-center justify-between gap-3">
                  <div class="min-w-0">
                    <p class="text-sm font-semibold text-gray-900 group-hover:text-blue-600 transition-colors truncate">{{ product.name[lang] | default(product.name.it) }}</p>
                    <p class="text-xs text-gray-500 truncate">{{ product.manufacturer }}</p>
                  </div>
                  <div class="shrink-0 text-right">
                    <p class="text-[11px] font-mono text-gray-400">#{{ product.number }}</p>
                    <span class="text-blue-600 text-[11px] font-semibold">{{ translations[lang].viewProduct }}</span>
                  </div>
                </div>
              </a>
            {% endfor %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>
