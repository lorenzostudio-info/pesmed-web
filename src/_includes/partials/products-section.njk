{# Products section - used on homepage AND products index page #}
<section class="py-16 md:py-24 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">{{ translations[lang].productsTitle }}</h2>
      <p class="text-gray-600 max-w-3xl mx-auto text-lg">{{ translations[lang].productsIntro }}</p>
    </div>

    {% set categoryIcons = {
      "cryotherapy-ablation": '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v2m0 14v2m-7-9H3m18 0h-2m-2.636-5.364l-1.414 1.414M7.05 16.95l-1.414 1.414m0-12.728l1.414 1.414M16.95 16.95l1.414 1.414M12 8a4 4 0 100 8 4 4 0 000-8z"/>',
      "electroporation-therapy": '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>',
      "surgical-navigation-imaging": '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/>'
    } %}

    {% set categoryColors = {
      "cryotherapy-ablation": { "bg": "bg-sky-50", "border": "border-sky-200", "accent": "text-sky-600", "badge": "bg-sky-100 text-sky-700", "hover": "hover:border-sky-400", "iconBg": "bg-sky-100" },
      "electroporation-therapy": { "bg": "bg-amber-50", "border": "border-amber-200", "accent": "text-amber-600", "badge": "bg-amber-100 text-amber-700", "hover": "hover:border-amber-400", "iconBg": "bg-amber-100" },
      "surgical-navigation-imaging": { "bg": "bg-emerald-50", "border": "border-emerald-200", "accent": "text-emerald-600", "badge": "bg-emerald-100 text-emerald-700", "hover": "hover:border-emerald-400", "iconBg": "bg-emerald-100" }
    } %}

    {% set categories = products | getCategories %}

    {% for cat in categories %}
      {% set catProducts = products | filterByCategory(cat) %}
      {% set colors = categoryColors[cat] %}
      {% set icon = categoryIcons[cat] %}
      {% set catName = translations[lang].categories[cat] %}

      <div class="mb-16 last:mb-0">
        {# Category header #}
        <div class="flex items-center mb-8">
          <div class="{{ colors.iconBg }} rounded-xl p-3 mr-4">
            <svg class="w-7 h-7 {{ colors.accent }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">{{ icon | safe }}</svg>
          </div>
          <div>
            <h3 class="text-2xl font-bold text-gray-900">{{ catName }}</h3>
            <p class="text-sm text-gray-500 mt-0.5">{{ catProducts | length }} {{ translations[lang].products | lower }}</p>
          </div>
          <div class="flex-1 ml-6 border-t border-gray-200"></div>
        </div>

        {# Product cards grid #}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {% for product in catProducts %}
            <a href="{{ '/' + lang + '/products/' + product.slug + '/' }}" class="group relative bg-white rounded-xl border-2 {{ colors.border }} {{ colors.hover }} shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden flex flex-col">
              {# Product image or placeholder #}
              {% if product.image %}
                <div class="{{ colors.bg }} p-6 flex items-center justify-center h-48">
                  <img src="{{ product.image }}" alt="{{ product.name[lang] }}" class="max-h-full w-auto object-contain group-hover:scale-105 transition-transform duration-300">
                </div>
              {% else %}
                <div class="{{ colors.bg }} p-6 flex items-center justify-center h-48">
                  <div class="text-center">
                    <span class="{{ colors.accent }} text-5xl font-bold opacity-30">{{ product.number }}</span>
                  </div>
                </div>
              {% endif %}

              {# Product info #}
              <div class="p-6 flex flex-col flex-1">
                <div class="flex items-center justify-between mb-3">
                  <span class="inline-flex items-center text-xs font-semibold px-2.5 py-1 rounded-full {{ colors.badge }}">{{ catName }}</span>
                  <span class="text-xs font-mono text-gray-400">#{{ product.number }}</span>
                </div>
                <h4 class="text-lg font-bold text-gray-900 group-hover:text-blue-600 transition-colors mb-2">{{ product.name[lang] | default(product.name.it) }}</h4>
                <p class="text-sm text-gray-600 line-clamp-2 mb-4 flex-1">{{ product.description[lang] | default(product.description.it) | truncate(120) }}</p>
                <div class="flex items-center justify-between mt-auto pt-4 border-t border-gray-100">
                  <span class="text-xs text-gray-500 font-medium">{{ product.manufacturer }}</span>
                  <span class="text-blue-600 text-sm font-semibold group-hover:translate-x-1 transition-transform duration-200 inline-flex items-center">
                    {{ translations[lang].viewProduct }}
                    <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                  </span>
                </div>
              </div>
            </a>
          {% endfor %}
        </div>
      </div>
    {% endfor %}
  </div>
</section>
