{# Hero section - used on homepage #}
<section class="relative bg-gray-900 text-white overflow-hidden">
  <div class="absolute inset-0">
    <img src="https://pesmed.lorenzostudio.info/wp-content/uploads/revslider/home-slider-11/slider-11-a.jpg" alt="PesMed Hero" class="w-full h-full object-cover opacity-40">
  </div>
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 md:py-48">
    <p class="text-white font-semibold tracking-widest text-[16px] uppercase mb-4">{{ translations[lang].heroWelcome }}</p>
    <h1 class="text-4xl md:text-6xl lg:text-[80px] leading-tight max-w-3xl text-white">
      <span>{{ translations[lang].heroSubtitle1 }}</span>
      <span class="font-bold underline">{{ translations[lang].heroSubtitleBold }}</span>
      <span>{{ translations[lang].heroSubtitle2 }}</span>
    </h1>
  </div>
</section>
