{# Hero section - used on homepage #}
<section class="relative bg-black text-white overflow-hidden"
  x-data="{
    currentSlide: 0,
    fading: false,
    slides: [
      'https://picsum.photos/seed/slide1/1920/1080',
      'https://picsum.photos/seed/slide2/1920/1080',
      'https://picsum.photos/seed/slide3/1920/1080'
    ],
    goTo(index) {
      if (this.fading) return;
      this.fading = true;
      setTimeout(() => {
        this.currentSlide = index;
        this.fading = false;
      }, 1000);
    }
  }"
  x-init="setInterval(() => { goTo((currentSlide + 1) % slides.length) }, 7000)">

  <div class="absolute inset-0 transition-opacity duration-1000"
    :class="fading ? 'opacity-0' : 'opacity-60'">
    <img :src="slides[currentSlide]" alt="PesMed Hero" class="w-full h-full object-cover">
  </div>

  <div class="absolute left-4 top-4 lg:top-1/2 lg:transform lg:-translate-y-1/2 z-10">
    <a href="https://www.linkedin.com/company/pes-med" target="_blank" class="text-white hover:text-blue-400 transition">
      <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24">
        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
      </svg>
    </a>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 md:py-48">
    <p class="text-white font-semibold tracking-widest text-[16px] uppercase mb-4">{{ translations[lang].heroWelcome }}</p>
    <h1 class="text-4xl md:text-6xl lg:text-[80px] leading-tight max-w-3xl text-white">
      <span>{{ translations[lang].heroSubtitle1 }}</span>
      <span class="font-bold underline">{{ translations[lang].heroSubtitleBold }}</span>
      <span>{{ translations[lang].heroSubtitle2 }}</span>
    </h1>
  </div>

  <div class="absolute bottom-4 left-1/2 transform -translate-x-1/2 z-10 flex space-x-2">
    <button @click="goTo(0)" class="w-3 h-3 rounded-full bg-white opacity-50 hover:opacity-100 transition" :class="{ 'opacity-100': currentSlide === 0 }"></button>
    <button @click="goTo(1)" class="w-3 h-3 rounded-full bg-white opacity-50 hover:opacity-100 transition" :class="{ 'opacity-100': currentSlide === 1 }"></button>
    <button @click="goTo(2)" class="w-3 h-3 rounded-full bg-white opacity-50 hover:opacity-100 transition" :class="{ 'opacity-100': currentSlide === 2 }"></button>
  </div>
</section>