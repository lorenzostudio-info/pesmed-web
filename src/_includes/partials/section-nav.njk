{# Section navigation cards (Home) - Version 4: minimal, sottili, senza bordo, stile testo #}
<section class="bg-white">
  <div class="max-w-2xl md:max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-8 md:mt-12 mb-0 md:mb-1">
    <div class="flex flex-row gap-2 justify-center md:grid md:grid-cols-3 md:gap-6">
      <a href="#about" class="group flex items-center justify-center w-full max-w-xs px-4 py-3 bg-transparent hover:bg-blue-50 rounded-xl transition focus:outline-none focus:ring-2 focus:ring-blue-200 active:scale-97 min-h-[48px]">
        <span class="text-lg sm:text-xl font-semibold text-gray-900 group-hover:text-blue-900 tracking-wide text-center">
          <span class="block md:hidden">About</span>
          <span class="hidden md:block">{{ translations[lang].aboutTitle }}</span>
        </span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-400 group-hover:text-blue-700 ml-3 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </a>
      <a href="#products-section" class="group flex items-center justify-center w-full max-w-xs px-4 py-3 bg-transparent hover:bg-blue-50 rounded-xl transition focus:outline-none focus:ring-2 focus:ring-blue-200 active:scale-97 min-h-[48px]">
        <span class="text-lg sm:text-xl font-semibold text-gray-900 group-hover:text-blue-900 tracking-wide text-center">
          <span class="block md:hidden">Explore</span>
          <span class="hidden md:block">{{ translations[lang].productsTitle }}</span>
        </span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-400 group-hover:text-blue-700 ml-3 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </a>
      <a href="#news-section" class="group flex items-center justify-center w-full max-w-xs px-4 py-3 bg-transparent hover:bg-blue-50 rounded-xl transition focus:outline-none focus:ring-2 focus:ring-blue-200 active:scale-97 min-h-[48px]">
        <span class="text-lg sm:text-xl font-semibold text-gray-900 group-hover:text-blue-900 tracking-wide text-center">
          <span class="block md:hidden">News</span>
          <span class="hidden md:block">{{ translations[lang].newsTitle }}</span>
        </span>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-blue-400 group-hover:text-blue-700 ml-3 transition" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </a>
    </div>
  </div>
</section>
