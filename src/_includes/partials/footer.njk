<footer class="relative bg-[#141570] text-blue-100 overflow-hidden">

  {# ── MAIN CONTENT ── #}
  <div class="relative z-10">

    {# Top section: logo + tagline | links grid | contact card #}
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 lg:gap-14 items-start">
        {# Col 1 – Brand and contact (always visible) #}
        <div class="flex flex-col gap-5">
          <img src="{{ site.footerLogo }}" alt="{{ site.name }}" class="h-20 w-auto brightness-200">
          <p class="text-sm leading-relaxed text-blue-100/75 max-w-xs">{{ translations[lang].aboutText }}</p>
          <div class="w-10 h-0.5 bg-blue-300/40 rounded"></div>
          <div class="flex flex-col gap-3 text-sm">
            <a href="tel:{{ site.phone }}" class="flex items-center gap-2 text-blue-100/80 hover:text-white transition-colors">
              <svg class="w-4 h-4 shrink-0 text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              {{ site.phone }}
            </a>
            <a href="mailto:{{ site.email }}" class="flex items-center gap-2 text-blue-100/80 hover:text-white transition-colors">
              <svg class="w-4 h-4 shrink-0 text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              {{ site.email }}
            </a>
            <span class="flex items-start gap-2 text-blue-100/80">
              <svg class="w-4 h-4 shrink-0 mt-0.5 text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              {{ site.address }}
            </span>
          </div>
        </div>
        {# Col 2 – Products (hidden on mobile) #}
        <div class="hidden md:block">
          <h4 class="text-xs font-bold uppercase tracking-widest text-blue-300 mb-5">{{ translations[lang].products }}</h4>
          <ul class="space-y-3 text-sm">
            {% for product in products %}
              <li>
                <a href="{{ '/products/' | locale_url }}{{ product.slug }}/" class="flex items-center gap-2 text-blue-100/75 hover:text-white transition-colors group">
                  <span class="w-1 h-1 rounded-full bg-blue-400 group-hover:bg-white transition-colors shrink-0"></span>
                  {{ product.name[lang] | default(product.name.it) }}
                </a>
              </li>
            {% endfor %}
          </ul>
        </div>
        {# Col 3 – Navigation + CTA (hidden on mobile) #}
        <div class="hidden md:flex flex-col gap-8">
          <div>
            <h4 class="text-xs font-bold uppercase tracking-widest text-blue-300 mb-5">{{ translations[lang].followUs }}</h4>
            <ul class="space-y-3 text-sm">
              <li><a href="{{ '/' | locale_url }}" class="flex items-center gap-2 text-blue-100/75 hover:text-white transition-colors group"><span class="w-1 h-1 rounded-full bg-blue-400 group-hover:bg-white transition-colors shrink-0"></span>{{ translations[lang].home }}</a></li>
              <li><a href="{{ '/news/' | locale_url }}" class="flex items-center gap-2 text-blue-100/75 hover:text-white transition-colors group"><span class="w-1 h-1 rounded-full bg-blue-400 group-hover:bg-white transition-colors shrink-0"></span>{{ translations[lang].articles }}</a></li>
              <li><a href="{{ '/contact/' | locale_url }}" class="flex items-center gap-2 text-blue-100/75 hover:text-white transition-colors group"><span class="w-1 h-1 rounded-full bg-blue-400 group-hover:bg-white transition-colors shrink-0"></span>{{ translations[lang].contact }}</a></li>
              <li><a href="{{ '/news/feed.xml' | locale_url }}" class="flex items-center gap-2 text-blue-100/75 hover:text-white transition-colors group"><span class="w-1 h-1 rounded-full bg-blue-400 group-hover:bg-white transition-colors shrink-0"></span>{{ translations[lang].rssFeed }}</a></li>
            </ul>
          </div>
          <a href="mailto:{{ site.email }}" class="group inline-flex items-center gap-3 rounded-xl border border-blue-400/30 bg-white/5 hover:bg-white/10 px-5 py-4 transition-all">
            <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-blue-400/20 group-hover:bg-blue-400/30 transition-colors">
              <svg class="w-4 h-4 text-blue-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </span>
            <div class="text-left">
              <p class="text-xs text-blue-300 font-semibold uppercase tracking-wide">{{ translations[lang].emailUs }}</p>
              <p class="text-sm text-white font-medium">{{ translations[lang].sendEmail }}</p>
            </div>
          </a>
        </div>
      </div>
    </div>

    {# Bottom bar #}
    <div class="border-t border-white/10">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex flex-col sm:flex-row justify-between items-center gap-2 text-xs text-blue-100/50">
        <p>{{ translations[lang].footerCopyright }} <a href="https://www.lorenzostudio.info/" class="text-blue-200/70 hover:text-white transition-colors" target="_blank" rel="noopener">Lorenzo Studio</a>. {{ translations[lang].allRightsReserved }}</p>
        <a href="{{ '/privacy-policy/' | locale_url }}" class="text-blue-200/70 hover:text-white transition-colors">{{ translations[lang].privacyPolicy }}</a>
      </div>
    </div>

  </div>
</footer>
