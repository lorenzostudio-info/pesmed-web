{# About section - used on homepage #}
<section id="about" class="py-16 md:py-24 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
      <div class="lg:col-span-6">
        <img src="https://labtechco-demo.pbminfotech.com/elementor-datasite2/wp-content/uploads/sites/36/2022/11/img-02.jpg" alt="About PesMed" class="rounded-2xl shadow-xl w-full h-[420px] object-cover">
      </div>

      <div class="lg:col-span-6">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">{{ translations[lang].aboutTitle }}</h2>
        <p class="text-gray-600 text-lg leading-relaxed max-w-2xl mb-10">{{ translations[lang].aboutText }}</p>
        <img src="https://labtechco-demo.pbminfotech.com/elementor-datasite2/wp-content/uploads/sites/36/2022/11/img-01.jpg" alt="Medical Devices" class="rounded-2xl shadow-xl w-full h-64 object-cover">
      </div>
    </div>
  </div>
</section>
