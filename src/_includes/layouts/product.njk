---
layout: layouts/base.njk
---

{# Product detail layout #}

{# `src/*/products/product.njk` paginates `products` with alias `product`.
  Use that directly to avoid mis-resolution when `productSlug` is missing. #}
{% set productData = product %}

{% set breadcrumbs = [{label: translations[lang].products, url: '/products/' | locale_url}, {label: productData.name[lang] if productData.name[lang] else title}] %}
{% include "partials/breadcrumb.njk" %}

{% set pageTitle = productData.name[lang] if productData.name[lang] else title %}
{% include "partials/page-header.njk" %}

<section class="py-12 md:py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

      {# LEFT COLUMN: media #}
      <div>
        {% if productData.videoUrl %}
          <div class="mb-6 bg-white rounded-lg shadow-md overflow-hidden border border-gray-200">
            <iframe class="w-full aspect-video"
              src="https://www.youtube.com/embed/{{ (productData.videoUrl | replace('https://www.youtube.com/watch?v=', '') | replace('https://youtu.be/', '')) }}"
              title="{{ productData.name[lang] if productData.name[lang] else title }}"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              referrerpolicy="strict-origin-when-cross-origin"
              allowfullscreen></iframe>
            <div class="px-4 py-2 text-sm text-gray-600">{{ translations[lang].watchVideo }}</div>
          </div>
        {% endif %}

        {# Gallery source priority:
           1. scrollableImages[] — explicit scrollable subset (e.g. iFIX)
           2. images[]           — full list
           3. image              — single fallback (no lightbox) #}
        {% set galleryImages = productData.scrollableImages if (productData.scrollableImages and productData.scrollableImages.length) else (productData.images if (productData.images and productData.images.length) else []) %}
        {% set useCarousel = galleryImages.length > 4 %}

        {% if galleryImages.length %}
          {# Alpine.js gallery component #}
          <div
            x-data="{
              thumbs: [],
              open: false,
              current: 0,
              total: 0,
              lightboxSrc: '',
              init() {
                this.thumbs = Array.from(this.$root.querySelectorAll('[data-gallery-thumb]'));
                this.total = this.thumbs.length;
              },
              getSrc(idx) {
                const el = this.thumbs[idx];
                if (!el) return '';
                const img = el.querySelector('img');
                return img ? img.src : '';
              },
              show(idx) { this.current = idx; this.lightboxSrc = this.getSrc(idx); this.open = true; },
              prev() { this.current = (this.current - 1 + this.total) % this.total; this.lightboxSrc = this.getSrc(this.current); },
              next() { this.current = (this.current + 1) % this.total; this.lightboxSrc = this.getSrc(this.current); },
              close() { this.open = false; }
            }"
            @keydown.escape.window="if(open) close()"
            @keydown.arrow-left.window="if(open) prev()"
            @keydown.arrow-right.window="if(open) next()"
          >
            {% if useCarousel %}
              {# Carousel with prev/next buttons (for iFIX and similar) #}
              <div x-data="{ slide: 0, carouselTotal: {{ galleryImages.length }} }" class="relative">
                {# Main large image display #}
                <div class="relative bg-gray-50 rounded-xl shadow-md overflow-hidden min-h-[260px] sm:min-h-[340px] md:min-h-[400px]">
                  {% for img in galleryImages %}
                    <div x-show="slide === {{ loop.index0 }}" x-cloak x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100" x-transition:leave="transition ease-in duration-200" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0" class="absolute inset-0 flex items-center justify-center p-3 sm:p-4 cursor-zoom-in" @click="show({{ loop.index0 }})" data-gallery-thumb>
                      <img src="{{ img }}"
                        alt="{{ productData.name[lang] if productData.name[lang] else title }} {{ loop.index }}"
                        class="max-h-[220px] sm:max-h-[300px] md:max-h-[500px] w-auto max-w-full object-contain rounded-lg">
                    </div>
                  {% endfor %}
                </div>

                {# Prev / Next buttons #}
                <button type="button" @click="slide = (slide - 1 + carouselTotal) % carouselTotal"
                  class="absolute left-2 top-1/2 -translate-y-1/2 bg-white/90 hover:bg-white text-gray-700 hover:text-gray-900 shadow-lg rounded-full p-2 sm:p-3 transition-all z-10 focus:outline-none focus:ring-2 focus:ring-blue-400"
                  aria-label="Previous">
                  <svg class="w-4 h-4 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                  </svg>
                </button>
                <button type="button" @click="slide = (slide + 1) % carouselTotal"
                  class="absolute right-2 top-1/2 -translate-y-1/2 bg-white/90 hover:bg-white text-gray-700 hover:text-gray-900 shadow-lg rounded-full p-2 sm:p-3 transition-all z-10 focus:outline-none focus:ring-2 focus:ring-blue-400"
                  aria-label="Next">
                  <svg class="w-4 h-4 sm:w-6 sm:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </button>

                {# Dot indicators #}
                <div class="flex items-center justify-center gap-2 mt-4">
                  {% for img in galleryImages %}
                    <button type="button" @click="slide = {{ loop.index0 }}"
                      :class="slide === {{ loop.index0 }} ? 'bg-blue-600 scale-125' : 'bg-gray-300 hover:bg-gray-400'"
                      class="w-2.5 h-2.5 rounded-full transition-all duration-200 focus:outline-none"
                      aria-label="Go to image {{ loop.index }}"></button>
                  {% endfor %}
                </div>

                {# Counter #}
                <p class="text-center text-sm text-gray-500 mt-2">
                  <span x-text="slide + 1"></span> / {{ galleryImages.length }}
                </p>
              </div>
            {% elif galleryImages.length <= 2 %}
              {# 1 or 2 images: display large, stacked vertically #}
              <div class="space-y-6">
                {% for img in galleryImages %}
                  <button type="button" @click="show({{ loop.index0 }})" class="focus:outline-none rounded-xl w-full block" data-gallery-thumb>
                    <img src="{{ img }}"
                      alt="{{ productData.name[lang] if productData.name[lang] else title }} {{ loop.index }}"
                      class="rounded-xl shadow-md w-full h-auto object-contain bg-gray-50 p-6 cursor-zoom-in hover:shadow-lg hover:scale-[1.005] transition-all duration-200"
                      style="min-height: 280px;">
                  </button>
                {% endfor %}
              </div>
            {% else %}
              {# 3-4 images: 2-column grid #}
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {% for img in galleryImages %}
                  <button type="button" @click="show({{ loop.index0 }})" class="focus:outline-none rounded-lg w-full" data-gallery-thumb>
                    <img src="{{ img }}"
                      alt="{{ productData.name[lang] if productData.name[lang] else title }} {{ loop.index }}"
                      class="rounded-lg shadow-md w-full h-auto object-contain bg-gray-50 p-4 cursor-zoom-in hover:shadow-lg hover:scale-[1.01] transition-all duration-200">
                  </button>
                {% endfor %}
              </div>
            {% endif %}

            {# ===== LIGHTBOX OVERLAY ===== #}
            <div
              x-show="open"
              x-cloak
              x-transition:enter="transition ease-out duration-200"
              x-transition:enter-start="opacity-0"
              x-transition:enter-end="opacity-100"
              x-transition:leave="transition ease-in duration-150"
              x-transition:leave-start="opacity-100"
              x-transition:leave-end="opacity-0"
              @click.self="close()"
              class="fixed inset-0 z-[9999] flex items-center justify-center bg-black/85 backdrop-blur-sm p-4"
              role="dialog"
              aria-modal="true"
              style="display: none;"
            >
              {# Close button #}
              <button type="button" @click="close()"
                class="absolute top-4 right-4 text-white/80 hover:text-white transition-colors z-10"
                aria-label="Close">
                <svg class="w-9 h-9" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
              </button>
              {# Prev button #}
              <button type="button" @click="prev()"
                class="absolute left-3 sm:left-5 top-1/2 -translate-y-1/2 text-white/80 hover:text-white bg-black/30 hover:bg-black/50 rounded-full p-2 transition-all z-10"
                aria-label="Previous">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
              </button>
              {# Lightbox image — src is extracted from the Eleventy-optimized thumbnail at runtime #}
              <img x-ref="lightboxImg" x-bind:src="lightboxSrc" x-show="lightboxSrc" alt="" class="max-w-[90vw] max-h-[85vh] object-contain rounded-xl shadow-2xl" eleventy:ignore>
              {# Next button #}
              <button type="button" @click="next()"
                class="absolute right-3 sm:right-5 top-1/2 -translate-y-1/2 text-white/80 hover:text-white bg-black/30 hover:bg-black/50 rounded-full p-2 transition-all z-10"
                aria-label="Next">
                <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </button>
              {# Counter #}
              <span x-text="(current + 1) + ' / ' + total"
                class="absolute bottom-5 left-1/2 -translate-x-1/2 text-white/60 text-sm tabular-nums z-10"></span>
            </div>

          </div>
        {% elif productData.image %}
          <img src="{{ productData.image }}"
            alt="{{ productData.name[lang] if productData.name[lang] else title }}"
            class="rounded-lg shadow-md w-full h-auto object-contain bg-gray-50 p-4">
        {% endif %}
      </div>

      {# RIGHT COLUMN: product info #}
      <div>
        <div class="mb-4">
          <span class="inline-block bg-blue-100 text-blue-800 text-xs font-semibold px-3 py-1 rounded-full">
            {{ translations[lang].manufacturer }}: {{ productData.manufacturer }}
          </span>
        </div>
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6">
          {{ productData.name[lang] if productData.name[lang] else title }}
        </h2>
        {% if productData.subtitle %}
          <p class="text-lg text-blue-700 font-semibold -mt-3 mb-5">
            {{ productData.subtitle[lang] if productData.subtitle[lang] else productData.subtitle.it }}
          </p>
        {% endif %}
        <div class="prose prose-lg text-gray-600 leading-relaxed">
          <p>{{ productData.description[lang] if productData.description[lang] else productData.description.it }}</p>
        </div>

        {# Content sections — alternating blue / emerald cards #}
        {% set sectionItems = [] %}
        {% if productData.contentSections and productData.contentSections[lang] %}
          {% set sectionItems = productData.contentSections[lang] %}
        {% elif productData.contentSections and productData.contentSections.it %}
          {% set sectionItems = productData.contentSections.it %}
        {% endif %}

        {% if sectionItems.length %}
          {% for sec in sectionItems %}
            {% if loop.index is odd %}
              {% set secBg = "bg-blue-50 border-blue-300" %}
              {% set secTitle = "text-blue-950" %}
              {% set secText = "text-blue-900" %}
              {% set secBullet = "text-blue-600" %}
            {% else %}
              {% set secBg = "bg-teal-50 border-teal-300" %}
              {% set secTitle = "text-teal-950" %}
              {% set secText = "text-teal-900" %}
              {% set secBullet = "text-teal-600" %}
            {% endif %}
            <div class="mt-8 p-6 rounded-lg border {{ secBg }}">
              {% if sec.title %}
                <h3 class="text-xl font-semibold {{ secTitle }} mb-3">{{ sec.title }}</h3>
              {% endif %}
              {% if sec.paragraphs and sec.paragraphs.length %}
                <div class="space-y-3 {{ secText }} leading-relaxed">
                  {% for par in sec.paragraphs %}
                    <p>{{ par }}</p>
                  {% endfor %}
                </div>
              {% endif %}
              {% if sec.items and sec.items.length %}
                <ul class="mt-4 space-y-2">
                  {% for item in sec.items %}
                    <li class="flex items-start {{ secText }}">
                      <svg class="w-4 h-4 {{ secBullet }} mr-2 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <circle cx="10" cy="10" r="3"/>
                      </svg>
                      <span>{{ item }}</span>
                    </li>
                  {% endfor %}
                </ul>
              {% endif %}
              {% if sec.footer %}
                <p class="mt-4 {{ secText }} leading-relaxed">{{ sec.footer }}</p>
              {% endif %}
            </div>
          {% endfor %}
        {% endif %}

        {# More info + brochures (ProSense) #}
        {% if productData.moreInfo %}
          <div class="mt-8 p-6 bg-gray-50 rounded-lg">
            <h3 class="text-xl font-semibold text-gray-900 mb-3">{{ translations[lang].moreInfo }}</h3>
            <p class="text-gray-600 mb-4">{{ productData.moreInfo[lang] if productData.moreInfo[lang] else productData.moreInfo.it }}</p>
            {% if productData.brochures %}
              <ul class="space-y-2">
                {% for brochure in productData.brochures %}
                  <li>
                    <a href="{{ brochure.url }}" target="_blank" rel="noopener"
                      class="text-blue-600 hover:text-blue-800 font-medium flex items-center">
                      <svg class="w-5 h-5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                      </svg>
                      {{ brochure.name }}
                    </a>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </div>
        {% endif %}

        {# Key benefits #}
        {% if productData.benefits %}
          <div class="mt-8 p-6 bg-blue-50 rounded-lg border border-blue-300">
            <h3 class="text-xl font-semibold text-blue-950 mb-4">{{ translations[lang].keyBenefits }}</h3>
            <ul class="space-y-3">
              {% for benefit in productData.benefits[lang] if productData.benefits[lang] %}
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-blue-600 mr-3 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                  <span class="text-gray-700">{{ benefit }}</span>
                </li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}

        {# Clinical targets — emerald/green, shown FIRST for PIUR #}
        {% if productData.clinicalTargets %}
          <div class="mt-8 p-6 bg-teal-50 rounded-lg border border-teal-300">
            <h3 class="text-xl font-semibold text-teal-950 mb-4">{{ translations[lang].clinicalTargets }}</h3>
            <ul class="space-y-2">
              {% for target in productData.clinicalTargets[lang] if productData.clinicalTargets[lang] %}
                <li class="flex items-center">
                  <svg class="w-4 h-4 text-teal-600 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <circle cx="10" cy="10" r="3"/>
                  </svg>
                  <span class="text-gray-700">{{ target }}</span>
                </li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}

        {# Clinical benefits — sky/blue, shown AFTER for PIUR #}
        {% if productData.clinicalBenefits %}
          <div class="mt-8 p-6 bg-blue-50 rounded-lg border border-blue-300">
            <h3 class="text-xl font-semibold text-blue-950 mb-4">{{ translations[lang].clinicalBenefits }}</h3>
            <ul class="space-y-3">
              {% for benefit in productData.clinicalBenefits[lang] if productData.clinicalBenefits[lang] %}
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-blue-600 mr-3 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  <span class="text-gray-700">{{ benefit }}</span>
                </li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}

        {# YouTube channel button (ProSense) #}
        {% if productData.youtubeChannel %}
          <div class="mt-6">
            <a href="{{ productData.youtubeChannel }}" target="_blank" rel="noopener"
              class="inline-flex items-center bg-red-600 text-white px-6 py-3 rounded-lg hover:bg-red-700 transition-colors font-medium">
              <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
                <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
              {% if productData.youtubeLabel %}
                {{ productData.youtubeLabel[lang] if productData.youtubeLabel[lang] else productData.youtubeLabel.it }}
              {% else %}
                {{ translations[lang].youtubeChannel }}
              {% endif %}
            </a>
          </div>
        {% endif %}

        {# Inline markdown content #}
        {% if content | trim %}
          <div class="mt-8 prose prose-lg max-w-none">
            {{ content | safe }}
          </div>
        {% endif %}

        <div class="mt-8">
          <a href="{{ '/products/' | locale_url }}" class="text-blue-600 hover:text-blue-800 font-medium">
            ← {{ translations[lang].backToProducts }}
          </a>
        </div>
      </div>

    </div>
  </div>
</section>
