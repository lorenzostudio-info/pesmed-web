---
layout: layouts/base.njk
---

{# Product detail layout #}

{% set productData = products | findBySlug(productSlug) %}

{% set breadcrumbs = [{label: translations[lang].products, url: '/products/' | locale_url}, {label: productData.name[lang] if productData.name[lang] else title}] %}
{% include "partials/breadcrumb.njk" %}

{% set pageTitle = productData.name[lang] if productData.name[lang] else title %}
{% include "partials/page-header.njk" %}

<section class="py-12 md:py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
      {# Product images #}
      <div>
        {% if productData.images and productData.images.length %}
          <div class="grid grid-cols-2 gap-4">
            {% for img in productData.images %}
              <img src="{{ img }}" alt="{{ productData.name[lang] if productData.name[lang] else title }}" class="rounded-lg shadow-md w-full h-auto object-contain bg-gray-50 p-4">
            {% endfor %}
          </div>
        {% elif productData.image %}
          <img src="{{ productData.image }}" alt="{{ productData.name[lang] if productData.name[lang] else title }}" class="rounded-lg shadow-md max-w-sm mx-auto bg-gray-50 p-4">
        {% endif %}
      </div>

      {# Product info #}
      <div>
        <div class="mb-4">
          <span class="inline-block bg-blue-100 text-blue-800 text-xs font-semibold px-3 py-1 rounded-full">{{ translations[lang].manufacturer }}: {{ productData.manufacturer }}</span>
        </div>
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6">{{ productData.name[lang] if productData.name[lang] else title }}</h2>
        <div class="prose prose-lg text-gray-600 leading-relaxed">
          <p>{{ productData.description[lang] if productData.description[lang] else productData.description.it }}</p>
        </div>

        {# More info section #}
        {% if productData.moreInfo %}
          <div class="mt-8 p-6 bg-gray-50 rounded-lg">
            <h3 class="text-xl font-semibold text-gray-900 mb-3">{{ translations[lang].moreInfo }}</h3>
            <p class="text-gray-600 mb-4">{{ productData.moreInfo[lang] if productData.moreInfo[lang] else productData.moreInfo.it }}</p>
            {% if productData.brochures %}
              <ul class="space-y-2">
                {% for brochure in productData.brochures %}
                  <li>
                    <a href="{{ brochure.url }}" target="_blank" rel="noopener" class="text-blue-600 hover:text-blue-800 font-medium flex items-center">
                      <svg class="w-5 h-5 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                      {{ brochure.name }}
                    </a>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </div>
        {% endif %}

        {# YouTube channel #}
        {% if productData.youtubeChannel %}
          <div class="mt-6">
            <a href="{{ productData.youtubeChannel }}" target="_blank" rel="noopener" class="inline-flex items-center bg-red-600 text-white px-6 py-3 rounded-lg hover:bg-red-700 transition-colors font-medium">
              <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              {% if productData.youtubeLabel %}{{ productData.youtubeLabel[lang] if productData.youtubeLabel[lang] else productData.youtubeLabel.it }}{% else %}{{ translations[lang].youtubeChannel }}{% endif %}
            </a>
          </div>
        {% endif %}

        {# Markdown content from the page itself #}
        {% if content | trim %}
          <div class="mt-8 prose prose-lg max-w-none">
            {{ content | safe }}
          </div>
        {% endif %}

        <div class="mt-8">
          <a href="{{ '/products/' | locale_url }}" class="text-blue-600 hover:text-blue-800 font-medium">← {{ translations[lang].backToProducts }}</a>
        </div>
      </div>
    </div>
  </div>
</section>
