---
layout: layouts/base.njk
---

{# Article detail layout #}

{% set breadcrumbs = [{label: translations[lang].articles, url: '/articles/' | locale_url}, {label: title}] %}
{% include "partials/breadcrumb.njk" %}

{% set pageTitle = title %}
{% include "partials/page-header.njk" %}

<article class="py-12 md:py-20">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
      <time class="text-blue-600 font-semibold text-sm uppercase tracking-wide" datetime="{{ date | dateToRfc3339 if date | dateToRfc3339 else page.date.toISOString() }}">
        {{ page.date.toISOString().slice(0,10) }}
      </time>
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mt-2">{{ title }}</h1>
    </div>

    {% if image and not "/assets/social" in image %}
      <img src="{{ image }}" alt="{{ title }}" class="w-full rounded-lg shadow-md mb-8 max-h-96 object-cover">
    {% endif %}

    <div class="prose prose-lg max-w-none">
      {{ content | safe }}
    </div>

    <div class="mt-12 pt-8 border-t border-gray-200">
      <a href="{{ '/articles/' | locale_url }}" class="text-blue-600 hover:text-blue-800 font-medium">← {{ translations[lang].backToNews }}</a>
    </div>
  </div>
</article>
