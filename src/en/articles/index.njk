---
layout: layouts/base.njk
title: Articles
lang: en
description: 11ty-base is a minimal Eleventy starter with i18n (EN/IT) and RSS feeds, designed for clean, fast static sites.
---

<h2>Articles</h2>

{% for post in collections.articles_en %}
  <article>
    <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
    <small>{{ post.date.toISOString().slice(0,10) }}</small>
    <p>{{ post.data.description }}</p>
  </article>
{% endfor %}
