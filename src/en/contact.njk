---
layout: layouts/base.njk
title: Contact Us
lang: en
description: "Get in touch with us for information about our medical devices and services."
permalink: /en/contact/
---

{% set breadcrumbs = [{label: translations[lang].contact}] %}
{% include "partials/breadcrumb.njk" %}

{% set pageTitle = translations[lang].contact %}
{% include "partials/page-header.njk" %}

<section class="py-16 md:py-24 bg-gradient-to-b from-gray-50 to-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {# Page Title Section #}
    <div class="text-center mb-14">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-8 md:mb-10">{{ translations[lang].getInTouch }}</h2>
      <p class="max-w-4xl mx-auto text-lg md:text-xl leading-relaxed text-gray-600">{{ translations[lang].getInTouchText }}</p>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
      <div class="p-8 md:p-12">
        <h3 class="text-2xl md:text-3xl font-bold text-gray-900 mb-6">{{ translations[lang].ourSeat }}</h3>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <h4 class="text-xs uppercase font-bold text-gray-600 tracking-wide mb-2">Registered office</h4>
            <p class="text-gray-700 text-base leading-relaxed">Piazza del popolo 8/D, 44034 Copparo (FE)</p>
          </div>
          <div>
            <h4 class="text-xs uppercase font-bold text-gray-600 tracking-wide mb-2">Warehouse</h4>
            <p class="text-gray-700 text-base leading-relaxed">Via Domenico Fontana, 111/a, 80128 Napoli (NA)</p>
          </div>
        </div>

        <div class="mt-10 pt-8 border-t border-gray-200">
          <h4 class="text-lg font-bold text-gray-900 mb-4">{{ translations[lang].getInTouch }}</h4>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <a href="mailto:info@pesmed.it" class="flex items-center gap-3 p-3 bg-blue-50 hover:bg-blue-100 rounded-lg transition-colors duration-200 group">
              <div class="w-10 h-10 bg-blue-200 rounded-full flex items-center justify-center group-hover:bg-blue-300 transition-colors duration-200 flex-shrink-0">
                <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <div>
                <p class="text-xs uppercase text-gray-600 font-semibold">Email</p>
                <p class="text-blue-600 font-bold">info@pesmed.it</p>
              </div>
            </a>
            <a href="mailto:pesmed@legalmail.it" class="flex items-center gap-3 p-3 bg-blue-50 hover:bg-blue-100 rounded-lg transition-colors duration-200 group">
              <div class="w-10 h-10 bg-blue-200 rounded-full flex items-center justify-center group-hover:bg-blue-300 transition-colors duration-200 flex-shrink-0">
                <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <div>
                <p class="text-xs uppercase text-gray-600 font-semibold">PEC</p>
                <p class="text-blue-600 font-bold">pesmed@legalmail.it</p>
              </div>
            </a>
          </div>
          <div class="mt-6">
            <h4 class="text-xs uppercase font-bold text-gray-600 tracking-wide mb-2">VAT & Tax code</h4>
            <p class="text-gray-700 text-base leading-relaxed">01969220381</p>
          </div>
        </div>
      </div>
    </div>

    {# Final CTA Button #}
    <div class="flex justify-center mt-16">
      <a href="mailto:info@pesmed.it" class="inline-flex items-center gap-3 bg-blue-600 text-white px-12 py-4 rounded-lg hover:bg-blue-700 active:bg-blue-800 transition-all duration-200 font-semibold text-base shadow-lg hover:shadow-xl hover:scale-105 transform">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        {{ translations[lang].sendEmail }}
      </a>
    </div>
  </div>
</section>
