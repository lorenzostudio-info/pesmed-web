---
layout: layouts/base.njk
title: Contattaci
lang: it
description: "Contattateci per informazioni sui nostri dispositivi medici e servizi."
permalink: /it/contact/
---

{% set breadcrumbs = [{label: translations[lang].contact}] %}
{% include "partials/breadcrumb.njk" %}

{% set pageTitle = translations[lang].contactTitle %}
{% include "partials/page-header.njk" %}

<section class="py-16 md:py-24 bg-gradient-to-b from-gray-50 to-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {# Page Title Section #}
    <div class="mb-20">
      <div class="max-w-4xl mx-auto text-center mb-16">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-blue-950 mb-6 uppercase">{{ translations[lang].getInTouch }}</h2>
        <p class="text-blue-950 text-base md:text-lg leading-relaxed max-w-2xl mx-auto">{{ translations[lang].getInTouchText }}</p>
      </div>
    </div>

    {# Additional Contact Section with Map #}
    <div class="max-w-6xl mx-auto bg-white rounded-xl border border-gray-200 overflow-hidden">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-0">
        {# Left side - Google Maps #}
        <div class="lg:col-span-1 h-96 lg:h-auto min-h-80">
          <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3024.1234567890123!2d-74.0000000!3d40.7127753!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89c25a27aad7119b%3A0x1234567890ab!2s2946%20Angus%20Rd%2C%20New%20York!5e0!3m2!1sen!2sus!4v1234567890" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" class="block"></iframe>
        </div>

        {# Right side - Our Seat Info + Contacts #}
        <div class="p-8 md:p-12 flex flex-col justify-center">
          <h3 class="text-2xl md:text-3xl font-bold text-blue-950 mb-6">{{ translations[lang].ourSeat }}</h3>

          {# Address Block #}
          <div class="mb-8 pb-8 border-b border-gray-200">
            <h4 class="text-xs uppercase font-bold text-gray-600 tracking-wide mb-2">{{ translations[lang].ourAddress }}</h4>
            <p class="text-gray-700 text-base leading-relaxed">{{ site.address }}</p>
          </div>

          {# Contacts Block #}
          <div class="mb-8 pb-8 border-b border-gray-200">
            <h4 class="text-lg font-bold text-gray-900 mb-4">{{ translations[lang].getInTouch }}</h4>
            <div class="space-y-3">
              <a href="tel:{{ site.phone }}" class="flex items-center gap-3 p-3 bg-blue-50 hover:bg-blue-100 rounded-lg transition-colors duration-200 group">
                <div class="w-10 h-10 bg-blue-200 rounded-full flex items-center justify-center group-hover:bg-blue-300 transition-colors duration-200 flex-shrink-0">
                  <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                </div>
                <div>
                  <p class="text-xs uppercase text-gray-600 font-semibold">{{ translations[lang].callUs }}</p>
                  <p class="text-blue-600 font-bold">{{ site.phone }}</p>
                </div>
              </a>
              <a href="mailto:{{ site.email }}" class="flex items-center gap-3 p-3 bg-blue-50 hover:bg-blue-100 rounded-lg transition-colors duration-200 group">
                <div class="w-10 h-10 bg-blue-200 rounded-full flex items-center justify-center group-hover:bg-blue-300 transition-colors duration-200 flex-shrink-0">
                  <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <div>
                  <p class="text-xs uppercase text-gray-600 font-semibold">{{ translations[lang].emailUs }}</p>
                  <p class="text-blue-600 font-bold">{{ translations[lang].sendEmail }}</p>
                </div>
              </a>
            </div>
          </div>

          {# Working Hours Block #}
          <div>
            <h4 class="text-xs uppercase font-bold text-gray-600 tracking-wide mb-2">{{ translations[lang].workingHours }}</h4>
            <p class="text-gray-700 text-base">{{ translations[lang].workingHoursValue }}</p>
          </div>
        </div>
      </div>
    </div>

    {# Final CTA Button #}
    <div class="flex justify-center mt-16">
      <a href="mailto:contact@pesmed.it" class="inline-flex items-center gap-3 bg-blue-600 text-white px-12 py-4 rounded-lg hover:bg-blue-700 active:bg-blue-800 transition-all duration-200 font-semibold text-base shadow-lg hover:shadow-xl hover:scale-105 transform">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        {{ translations[lang].sendEmail }}
      </a>
    </div>
  </div>
</section>
